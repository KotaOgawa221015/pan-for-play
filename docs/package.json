{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "tsx .vitepress/scripts/generate-docs-index.ts",
    "dev": "vitepress dev .",
    "prebuild": "tsx .vitepress/scripts/generate-docs-index.ts",
    "build": "GITHUB_ACTIONS=true vitepress build .",
    "preview": "pnpm build && vitepress preview . --base /pan-for-play/",
    "test:rendered:preview": "pnpm build && GITHUB_ACTIONS=true playwright test --config .vitepress/tests/playwright.preview.config.ts",
    "test:rendered:dev": "playwright test --config .vitepress/tests/playwright.dev.config.ts",
    "test:rendered": "pnpm test:rendered:preview && pnpm test:rendered:dev"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "dotenv": "^17.4.2",
    "mermaid": "^11.15.0",
    "nunjucks": "^3.2.4",
    "tsx": "catalog:",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
