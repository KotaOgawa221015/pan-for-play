<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="inventory-erd" name="Inventory ERD">
    <mxGraphModel dx="1341" dy="880" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
