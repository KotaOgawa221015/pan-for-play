        <mxCell id="edgeUploadInventory" edge="1" parent="1" source="uploadBatch" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;strokeWidth=1.5;dashed=1;dashPattern=6 4;strokeColor=#666666;startArrow=ERone;startFill=0;endArrow=ERzeroToMany;endFill=0;" target="inventoryCheck" value="">
          <mxGeometry relative="1" as="geometry">
