        <mxCell id="edgeUserUpload" edge="1" parent="1" source="user" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;strokeWidth=2;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;" target="uploadBatch" value="">
          <mxGeometry relative="1" as="geometry" />
