        <mxCell id="rules" parent="1" style="shape=note;whiteSpace=wrap;html=1;size=18;align=left;spacingLeft=10;spacingTop=8;fontSize=13;fillColor=#ffffff;strokeColor=#666666;" value="&lt;b&gt;Business rules&lt;/b&gt;&lt;hr/&gt;FEW_LEFT = 1 to 5 items remaining.&lt;br/&gt;Manual updates and uploaded invoices both create InventoryCheck rows.&lt;br/&gt;UploadBatchLine keeps OCR review evidence before stock changes are applied.&lt;br/&gt;Optional references are shown as FK columns to keep the diagram readable." vertex="1">
          <mxGeometry height="120" width="1180" x="60" y="740" as="geometry" />
        </mxCell>
        <mxCell id="edgeProductInventory" edge="1" parent="1" source="product" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;strokeWidth=2;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;" target="inventoryCheck" value="">
          <mxGeometry relative="1" as="geometry">
