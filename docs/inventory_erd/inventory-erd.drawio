        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Pancolle Inventory ERD" vertex="1">
          <mxGeometry height="40" width="380" x="60" y="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontColor=#666666;" value="Current stock is derived from the latest InventoryCheck per Product." vertex="1">
          <mxGeometry height="30" width="560" x="60" y="70" as="geometry" />
        </mxCell>
        <mxCell id="product" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=8;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Product&lt;/b&gt;&lt;hr/&gt;PK id&lt;br/&gt;name UNIQUE&lt;br/&gt;isActive&lt;br/&gt;createdAt&lt;br/&gt;updatedAt" vertex="1">
          <mxGeometry height="165" width="280" x="70" y="160" as="geometry" />
        </mxCell>
        <mxCell id="user" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=8;fontSize=14;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;User&lt;/b&gt;&lt;hr/&gt;PK id&lt;br/&gt;email UNIQUE&lt;br/&gt;passwordHash&lt;br/&gt;displayName&lt;br/&gt;role (ADMIN | MEMBER)&lt;br/&gt;createdAt&lt;br/&gt;updatedAt" vertex="1">
          <mxGeometry height="205" width="300" x="490" y="15" as="geometry" />
        </mxCell>
        <mxCell id="uploadBatch" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=8;fontSize=14;fillColor=#f8cecc;strokeColor=#b85450;" value="&lt;b&gt;UploadBatch&lt;/b&gt;&lt;hr/&gt;PK id&lt;br/&gt;FK uploadedByUserId -&gt; User.id&lt;br/&gt;originalFileName&lt;br/&gt;storagePath&lt;br/&gt;processingStatus&lt;br/&gt;processedAt NULL&lt;br/&gt;createdAt&lt;br/&gt;updatedAt" vertex="1">
          <mxGeometry height="200" width="340" x="920" y="150" as="geometry" />
        </mxCell>
        <mxCell id="inventoryCheck" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=8;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;InventoryCheck&lt;/b&gt;&lt;hr/&gt;&lt;font face=&quot;Menlo, Monaco, monospace&quot;&gt;id: PK, text&lt;br/&gt;productId: FK -&gt; Product.id, text&lt;br/&gt;checkedByUserId: FK -&gt; User.id, text&lt;br/&gt;uploadBatchId: FK -&gt; UploadBatch.id, text, NULL&lt;br/&gt;status: enum&lt;br/&gt;sourceType: enum&lt;br/&gt;checkedAt: datetime&lt;br/&gt;note: text, NULL&lt;br/&gt;createdAt: datetime&lt;/font&gt;" vertex="1">
          <mxGeometry height="220" width="500" x="30" y="470" as="geometry" />
        </mxCell>
        <mxCell id="uploadBatchLine" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=10;spacingTop=8;fontSize=14;fillColor=#e1d5e7;strokeColor=#9673a6;" value="&lt;b&gt;UploadBatchLine&lt;/b&gt;&lt;hr/&gt;&lt;font face=&quot;Menlo, Monaco, monospace&quot;&gt;id: PK, text&lt;br/&gt;uploadBatchId: FK -&gt; UploadBatch.id, text&lt;br/&gt;lineNumber: integer&lt;br/&gt;rawText: text&lt;br/&gt;matchedProductId: FK -&gt; Product.id, text, NULL&lt;br/&gt;matchStatus: enum&lt;br/&gt;appliedStatus: enum, NULL&lt;br/&gt;createdAt: datetime&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="470" x="860" y="470" as="geometry" />
