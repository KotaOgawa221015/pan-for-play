{
  "name": "pancolle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "pnpm exec tsx scripts/turso-migrate.ts && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "typecheck": "prisma generate && next typegen && tsc --noEmit",
    "fix": "pnpm format && pnpm lint:fix",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "rm -rf coverage && vitest run --coverage",
    "test:system": "playwright test",
    "test:system:ui": "playwright test --ui",
    "db:setup": "prisma generate && prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "docs:preview": "cd docs && pnpm preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^3.0.3",
    "jimp": "^1.6.1",
    "next": "16.2.5",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "catalog:",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  }
}
