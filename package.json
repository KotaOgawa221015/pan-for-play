{
  "name": "pancolle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run build:ocr-worker && next build",
    "build:ocr-worker": "tsx scripts/build-ocr-worker.ts",
    "vercel-build": "pnpm exec tsx scripts/turso-migrate.ts && pnpm run build",
    "start": "next start",
    "postinstall": "prisma generate",
    "setup": "bash -euo pipefail -c '(test -f .env || cp .env.example .env) && pnpm install \"$@\" && pnpm exec playwright install && pnpm exec tsx scripts/db.ts setup' _",
    "check": "biome check . && pnpm run typecheck",
    "fix": "biome check --write .",
    "clean": "sudo rm -rf .tmp coverage node_modules dist",
    "typecheck": "prisma generate && next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "rm -rf coverage && vitest run --coverage",
    "test:system": "playwright test",
    "test:system:ui": "playwright test --ui",
    "db:setup": "prisma generate && prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "docs:preview": "cd docs && pnpm preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "heic-convert": "^2.1.0",
    "jimp": "^1.6.1",
    "next": "16.2.5",
    "next-auth": "5.0.0-beta.31",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "catalog:",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "catalog:",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  }
}
