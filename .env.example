# Database Settings
# Development: Local SQLite (file:./data/dev.db)
# Production: Turso (libsql://your-db-name.turso.io)
DATABASE_URL="file:./data/dev.db"

# Turso Authentication Token (Required for production)
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Turso database recreation settings
TURSO_DATABASE_NAME="pancolle-db"
# TURSO_DATABASE_GROUP is optional. Leave empty to use Turso's default group.
TURSO_DATABASE_GROUP=""
# Token expiration passed to `turso db tokens create`. Required by scripts/turso-recreate.js.
TURSO_AUTH_TOKEN_EXPIRATION="never"

# --- Docker Compose Settings ---
PANCOLLE_BIND_IP=127.0.0.1
PANCOLLE_PORT=3000
