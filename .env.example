# Database Settings
# Development: Local SQLite (file:./data/dev.db)
# Production: Turso (libsql://your-db-name.turso.io)
DATABASE_URL="file:./data/dev.db"

# Turso Authentication Token (Required for production)
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Turso database recreation settings
TURSO_DATABASE_NAME="pan-for-play-db"
# TURSO_DATABASE_GROUP is optional. Leave empty to use Turso's default group.
TURSO_DATABASE_GROUP=""
# Token expiration passed to `turso db tokens create`. Required by scripts/turso-recreate.ts.
TURSO_AUTH_TOKEN_EXPIRATION="never"

# --- Docker Compose Settings ---
P4P_HOST_IP=127.0.0.1
P4P_PORT=3000
P4P_SYSTEM_TEST_PORT=3001
# Docs rendering test server ports used by Playwright configs under docs/.vitepress/tests/.
DOCS_TEST_PREVIEW_PORT=4173
DOCS_TEST_DEV_PORT=4174

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

AUTH_SECRET=""
