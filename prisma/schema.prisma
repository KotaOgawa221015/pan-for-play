generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum InventoryStatus {
  PLENTIFUL
  FEW_LEFT
  SOLD_OUT
}

enum ProductCategory {
  BREAD
  SOUP
}

enum UploadBatchProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

enum UploadBatchLineMatchStatus {
  MATCHED
  UNMATCHED
  IGNORED
  NEEDS_REVIEW
}

enum UserRole {
  ADMIN
  MEMBER
}

model Product {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  category               ProductCategory         @default(BREAD)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  uploadBatchLines       UploadBatchLine[]
  inventoryStatusChanges InventoryStatusChange[]
}

model User {
  id                     String                  @id @default(cuid())
  name                   String
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  role                   UserRole                @default(MEMBER)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  uploadBatches          UploadBatch[]
  inventoryPublications  InventoryPublication[]
  inventoryStatusChanges InventoryStatusChange[]
  accounts               Account[]
  sessions               Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken     String?
  accessToken      String?
  expiresAt        Int?
  tokenType        String?
  scope             String?
  idToken          String?
  sessionState     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String 
  expires    DateTime

  @@unique([identifier, token])
}

model UploadBatch {
  id               String                    @id @default(cuid())
  uploadedByUserId String
  originalFileName String
  storagePath      String?
  processingStatus UploadBatchProcessingStatus @default(PENDING)
  processedAt      DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  uploadedByUser         User                   @relation(fields: [uploadedByUserId], references: [id])
  lines                  UploadBatchLine[]
  inventoryPublications InventoryPublication[]

  @@index([uploadedByUserId])
}

model UploadBatchLine {
  id               String                   @id @default(cuid())
  uploadBatchId    String
  lineNumber       Int
  rawText          String
  count            Int
  matchedProductId String?
  matchStatus      UploadBatchLineMatchStatus
  createdAt        DateTime                 @default(now())

  uploadBatch    UploadBatch @relation(fields: [uploadBatchId], references: [id])
  matchedProduct Product?    @relation(fields: [matchedProductId], references: [id])

  @@index([uploadBatchId, lineNumber])
  @@index([matchedProductId])
}

model InventoryPublication {
  id                String                  @id @default(cuid())
  uploadBatchId     String
  publishedByUserId String
  publishedAt       DateTime
  createdAt         DateTime                @default(now())

  uploadBatch            UploadBatch              @relation(fields: [uploadBatchId], references: [id])
  publishedByUser        User                     @relation(fields: [publishedByUserId], references: [id])
  inventoryStatusChanges InventoryStatusChange[]

  @@index([uploadBatchId])
  @@index([publishedByUserId])
  @@index([publishedAt])
}

model InventoryStatusChange {
  id                String              @id @default(cuid())
  publicationId     String?
  productId         String
  changedByUserId   String
  previousStatus    InventoryStatus?
  nextStatus        InventoryStatus
  changedAt         DateTime
  createdAt         DateTime            @default(now())

  publication   InventoryPublication? @relation(fields: [publicationId], references: [id])
  product       Product               @relation(fields: [productId], references: [id])
  changedByUser User                  @relation(fields: [changedByUserId], references: [id])

  @@index([productId, changedAt])
  @@index([publicationId, changedAt])
  @@index([changedByUserId])
}
