generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ProductStatus {
  PLENTIFUL
  FEW_LEFT
  SOLD_OUT
}

model Product {
  id        String   @id @default(cuid())
  name      String   @unique
  status    ProductStatus @default(PLENTIFUL)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  role         String   @default("MEMBER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
