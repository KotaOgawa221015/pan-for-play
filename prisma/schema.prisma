generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum InventoryStatus {
  PLENTIFUL
  FEW_LEFT
  SOLD_OUT
}

enum ProductCategory {
  BREAD
  SOUP
}

enum UploadBatchLineMatchStatus {
  MATCHED
  UNMATCHED
  IGNORED
  NEEDS_REVIEW
}

enum UserRole {
  ADMIN
  MEMBER
}

model Fridge {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  isDefault              Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?

  users                  User[]
  uploadBatches          UploadBatch[]
  inventoryPublications  InventoryPublication[]
  inventoryStatusChanges InventoryStatusChange[]
  currentInventories     CurrentInventory[]
}

model Product {
  id                     String                  @id @default(cuid())
  name                   String                  @unique
  category               ProductCategory         @default(BREAD)
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  uploadBatchLines       UploadBatchLine[]
  inventoryStatusChanges InventoryStatusChange[]
  currentInventories     CurrentInventory[]
}

model User {
  id                     String                  @id @default(cuid())
  favoriteFridgeId       String?
  name                   String
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  role                   UserRole                @default(MEMBER)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  uploadBatches          UploadBatch[]
  inventoryPublications  InventoryPublication[]
  inventoryStatusChanges InventoryStatusChange[]
  currentInventories     CurrentInventory[]
  accounts               Account[]
  sessions               Session[]
  favoriteFridge         Fridge?                 @relation(fields: [favoriteFridgeId], references: [id])
}
//Googleから返される値がスネークケースのため、スネークケースのままにしておく
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String 
  expires    DateTime

  @@unique([identifier, token])
}

model UploadBatch {
  id               String                    @id @default(cuid())
  fridgeId         String
  uploadedByUserId String
  originalFileName String
  sourceImageBytes Bytes?
  sourceImageMimeType String?
  processedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  fridge                 Fridge                 @relation(fields: [fridgeId], references: [id])
  uploadedByUser         User                   @relation(fields: [uploadedByUserId], references: [id])
  lines                  UploadBatchLine[]
  inventoryPublications InventoryPublication[]

  @@index([uploadedByUserId])
}

model UploadBatchLine {
  id               String                   @id @default(cuid())
  uploadBatchId    String
  lineNumber       Int
  rawText          String
  count            Int
  matchedProductId String?
  matchStatus      UploadBatchLineMatchStatus
  createdAt        DateTime                 @default(now())

  uploadBatch    UploadBatch @relation(fields: [uploadBatchId], references: [id])
  matchedProduct Product?    @relation(fields: [matchedProductId], references: [id])

  @@index([uploadBatchId, lineNumber])
  @@index([matchedProductId])
}

model InventoryPublication {
  id                String                  @id @default(cuid())
  fridgeId          String
  uploadBatchId     String
  publishedByUserId String
  publishedAt       DateTime
  createdAt         DateTime                @default(now())

  fridge                 Fridge                  @relation(fields: [fridgeId], references: [id]) 
  uploadBatch            UploadBatch              @relation(fields: [uploadBatchId], references: [id])
  publishedByUser        User                     @relation(fields: [publishedByUserId], references: [id])
  inventoryStatusChanges InventoryStatusChange[]

  @@index([fridgeId, publishedAt(sort: Desc)])
  @@index([uploadBatchId])
  @@index([publishedByUserId])
}

model InventoryStatusChange {
  id                String              @id @default(cuid())
  publicationId     String?
  fridgeId          String
  productId         String
  changedByUserId   String
  previousStatus    InventoryStatus?
  nextStatus        InventoryStatus
  changedAt         DateTime
  createdAt         DateTime            @default(now())

  fridge        Fridge                @relation(fields: [fridgeId], references: [id])
  publication   InventoryPublication? @relation(fields: [publicationId], references: [id])
  product       Product               @relation(fields: [productId], references: [id])
  changedByUser User                  @relation(fields: [changedByUserId], references: [id])

  @@index([fridgeId, productId, changedAt(sort: Desc)])
  @@index([publicationId, changedAt])
  @@index([changedByUserId])
}

model CurrentInventory {
  fridgeId            String
  productId           String
  count               Int
  status              InventoryStatus
  isVisible           Boolean         @default(true)
  lastPublishedAt     DateTime
  lastChangedAt       DateTime?
  lastChangedByUserId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  fridge            Fridge  @relation(fields: [fridgeId], references: [id])
  product           Product @relation(fields: [productId], references: [id])
  lastChangedByUser User?   @relation(fields: [lastChangedByUserId], references: [id])

  @@id([fridgeId, productId])
  @@index([fridgeId, isVisible])
  @@index([lastChangedByUserId])
}
